# Required env vars for scripts/run.py and scripts/push_to_gsheet.py
# In GitHub Actions, set these as repository Secrets and pass through the workflow `env:` block.
# Locally, copy to .env (in this folder) and fill in values.

# --- Chatwoot API ---
CHATWOOT_BASE_URL=https://chat.example.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_TOKEN=your_api_token_here

# --- Google Sheets push (push_to_gsheet.py) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# PEM private key — replace \n with literal \n in the value (or put real newlines if your shell supports it).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
DAILY_COUNTS_SPREADSHEET_ID=your_sheet_id_here
# Optional:
# DAILY_COUNTS_TAB_NAME=AY2026_Leads_Count

# --- Optional overrides ---
# INBOXES=2,13,16,18,19,20,21,22,23
# WORKERS=6
# SINCE=2025-10-01
# PRODUCT=mdcat
